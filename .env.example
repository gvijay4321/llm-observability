# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# Every service reads from the same root .env file.
# ──────────────────────────────────────────────────────────────

# ---- LLM providers ---------------------------------------------------------
# The chatbot shows a provider switcher built from whichever keys are set
# here. LLM_PROVIDER is just the one selected by default.
LLM_PROVIDER=gemini

# Google Gemini - free tier (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Groq - free, very fast (https://console.groq.com)
GROQ_API_KEY=

# OpenRouter - free models (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Hugging Face Inference Providers (OSS models)
# (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Optional per-provider model overrides (sensible defaults are built in):
#   GROQ_MODEL=llama-3.3-70b-versatile
#   OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# Ollama is local-only. Default `true` keeps the provider selectable for local
# dev (assumes `ollama serve` is reachable on :11434). Set to `false` on a
# hosted deploy with no daemon (e.g. Railway) so the UI shows Ollama in the
# picker but renders an explanation banner and disables send instead of
# letting requests time out against localhost:11434.
#   OLLAMA_AVAILABLE=false

# ---- Ingestion service -----------------------------------------------------
INGESTION_PORT=4000
# Public URL the SDK and chatbot use to reach the ingestion service
INGESTION_URL=http://localhost:4000
# Shared secret the SDK sends as a bearer token (set blank to disable auth)
INGESTION_API_KEY=dev-ingest-key

# ---- Database --------------------------------------------------------------
# SQLite (default - zero setup):   file:./data/observability.sqlite
# Postgres (used by docker-compose): postgres://obs:obs@localhost:5432/observability
DATABASE_URL=file:./data/observability.sqlite

# ---- Event queue -----------------------------------------------------------
# memory  -> in-process queue (default, no infra)
# redis   -> BullMQ-backed queue (used by docker-compose)
QUEUE_DRIVER=memory
REDIS_URL=redis://localhost:6379

# ---- Chatbot ---------------------------------------------------------------
CHATBOT_PORT=3000
# Where the chatbot's browser/server code reaches the ingestion API
NEXT_PUBLIC_INGESTION_URL=http://localhost:4000

# ---- Telemetry (OpenTelemetry) ---------------------------------------------
# The meter API is the same regardless of exporter; the exporter is chosen at
# boot. Default ships a Prometheus scrape endpoint on each service so the
# docker-compose Prometheus + Grafana stack works with no extra config. Set
# OTEL_METRICS_ENABLED=false to skip binding the ports (e.g. in tests).
OTEL_METRICS_ENABLED=true
PROMETHEUS_PORT=9464          # ingestion: http://localhost:9464/metrics
CHATBOT_PROMETHEUS_PORT=9465  # chatbot:   http://localhost:9465/metrics

# To push to a hosted OTLP backend (Grafana Cloud, Honeycomb, Datadog OTLP)
# instead, set OTEL_EXPORTER_OTLP_ENDPOINT — the code switches to OTLP and
# stops binding the scrape ports. Used on the Railway deployment.
#   OTEL_SERVICE_NAME=obs-ingestion          # or obs-chatbot per service
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-XX.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance_id:token)>
#   OTEL_RESOURCE_ATTRIBUTES=service.namespace=llm-observability,deployment.environment=railway
#   OTEL_METRIC_EXPORT_INTERVAL=15000        # push cadence in ms
