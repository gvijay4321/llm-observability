    {
      "type": "row",
      "title": "Ingestion pipeline",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Logs accepted (1m rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(ingestion_logs_received_total[1m]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Queue depth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "expr": "sum(ingestion_queue_depth)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Dead-letters (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "expr": "sum(increase(ingestion_logs_failed_total[5m]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "PII redactions (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "expr": "sum(increase(ingestion_pii_redactions_total[1h]))", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Processing duration (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 5,
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ingestion_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ingestion_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ingestion_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker outcomes (rate by outcome)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
