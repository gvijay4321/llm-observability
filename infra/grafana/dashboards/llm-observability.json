      "id": 6,
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(ingestion_processing_duration_seconds_count[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
